{
  "rewrites": [
    { "source": "/character", "destination": "/index.html" },
    { "source": "/quests", "destination": "/index.html" },
    { "source": "/quests/:id", "destination": "/index.html" },
    { "source": "/my-quests", "destination": "/index.html" },
    { "source": "/chronicle", "destination": "/index.html" },
    { "source": "/settings", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }]
    }
  ]
}
